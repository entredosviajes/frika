DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite; set these for PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=lingua_coach
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# S3 Storage (optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# AI APIs
# Gemini (primary) — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Legacy (optional, unused unless you switch back)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
